                  <zone forceUpdate='true' h='7528' id='26' type-v2='text' w='21243' x='636' y='6032'>
                    <formatted-text>
                      <run fontalignment='1' fontcolor='#333333' fontname='Tahoma' fontsize='11' italic='true'>Для начала исследования выбери категорию рынка</run>
                    </formatted-text>
                    <zone-style>
                      <format attr='border-color' value='#000000' />
                      <format attr='border-style' value='none' />
