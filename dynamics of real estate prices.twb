      <aliases enabled='yes' />
      <column caption='Процент роста' datatype='real' name='[Calculation_0855450360389661]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([value]) - LOOKUP(AVG([value]), -3)) / ABS(LOOKUP(AVG([value]), -3)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Средняя стоимость кв. метра' datatype='real' name='[Calculation_0855450367320095]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([value])' />
      </column>
      <column caption='Годовой прирост' datatype='real' name='[Calculation_1319719197237255]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([value]) - LOOKUP(AVG([value]), -12)) / ABS(LOOKUP(AVG([value]), -12)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
